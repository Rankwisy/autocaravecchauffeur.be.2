const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'TransportationService',
  name: 'Autocaravecchauffeur',
  description:
    "Location d'autocar et minibus avec chauffeur à Bruxelles pour transport de groupe",
  url: 'https://autocaravecchauffeur.be',
  logo:
    'https://ik.imagekit.io/by733ltn6/FAVICONS/favicon_io%20(8)/apple-touch-icon.png?updatedAt=1759666614409',
