              </li>
            </ul>
          </div>
        </article>

        <article class="bg-white rounded-2xl overflow-hidden shadow-xl hover:shadow-2xl transition-all group border border-gray-100">
          <div class="relative h-72 overflow-hidden">
            <img
              src="https://ik.imagekit.io/by733ltn6/FAVICONS/favicon_io%20(8)/AZ.png?updatedAt=1759667457479"
