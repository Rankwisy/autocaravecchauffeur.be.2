          <span>Obtenir mon devis gratuit — sans engagement</span>
          <ArrowRight class="h-5 w-5" />
        </a>
      </div>
    </div>
  </section>

  <!-- Introduction SEO -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
